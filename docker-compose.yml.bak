services:
  aider_runner:
    image: aider:latest
    container_name: aider_runner_blog
    user: "${CURRENT_UID:-1000}:${CURRENT_GID:-1000}"
    tty: true
    stdin_open: true
    volumes:
      # 호스트의 현재 폴더를 컨테이너의 /app에 바로 연결합니다.
      - /home/now0930/runner_blog:/app
      # 설정 저장용 폴더 (호스트의 .aider_config -> 컨테이너의 /app/.aider)
      - /home/now0930/runner_blog/.aider_config:/app/.aider
    environment:
      - GEMINI_API_KEY=${GEMINI_API_KEY}
      - OLLAMA_API_BASE=${OLLAMA_BASE}
      # HOME을 /app으로 설정해야 Aider가 /app/.aider 폴더를 정상적으로 사용합니다.
      - HOME=/app
    # 작업 디렉토리를 볼륨이 연결된 /app으로 변경합니다.
    working_dir: /app
    command: 
    # 1. 설계자(Architect) 모델: Gemini 설정
      - "--model"
      - "${GEMINI_MODEL}"  # 또는 gemini-1.5-flash
      # 2. 코더(Editor) 모델: 로컬 Qwen 설정
      - "--editor-model"
      - "${MAIN_MODEL}"
      # 3. 기타 최적화 옵션
      - "--architect"
      - "--auto-commits"
      - "--yes-always"
    restart: "no"

networks:
  default:
    name: runner_network
